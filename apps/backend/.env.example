# --- Prisma CLI (migrations / generate) ---
# Local SQLite file, resolved relative to prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# --- Runtime DB connection (libSQL driver adapter) ---
# Local dev: point at the same local SQLite file (relative to apps/backend).
# Production: a Turso URL, e.g. libsql://<db>-<org>.turso.io
TURSO_DATABASE_URL="file:./prisma/dev.db"
# Only required for remote Turso (libsql://). Leave unset for local file DBs.
# TURSO_AUTH_TOKEN=

# --- Server ---
PORT=3001
WEBAPP_URL=http://localhost:4321
# Set to "true" in production so session cookies require HTTPS.
SESSION_COOKIE_SECURE=false
# Cookie SameSite policy. Use "none" if the API and frontend are on different
# sites (e.g. *.run.app + custom domain); requires SESSION_COOKIE_SECURE=true.
# "lax" is fine for local dev or same-site (api.example.com + app.example.com).
SESSION_COOKIE_SAMESITE=lax