generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  color String
}

model Expense {
  id          Int      @id @default(autoincrement())
  description String
  amount      Float
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
