# Cloud CDN / Cloud Storage deploy configuration (read by deploy.sh and infra/setup-cdn.sh).
# These are non-secret identifiers. The static site is served by a Cloud Storage bucket
# behind an external HTTPS Load Balancer with Cloud CDN enabled.
GCP_PROJECT=juan-custom-apps
GCP_REGION=us-central1
DOMAIN=expenser.juanromerodev.com

# Cloud Storage bucket holding the built static files (apps/webapp/dist).
BUCKET=expenser-webapp

# Load balancer / CDN resource names.
IP_NAME=expenser-webapp-ip
CERT_NAME=expenser-webapp-cert
BACKEND_BUCKET=expenser-webapp-be
URLMAP=expenser-webapp-urlmap
HTTPS_PROXY=expenser-webapp-https-proxy
HTTP_PROXY=expenser-webapp-http-proxy
REDIRECT_URLMAP=expenser-webapp-redirect
FR_HTTPS=expenser-webapp-fr-https
FR_HTTP=expenser-webapp-fr-http
