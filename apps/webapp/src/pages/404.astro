---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Not Found - Expenser">
  <main class="flex min-h-screen flex-col items-center justify-center gap-4 px-6 text-center">
    <p class="text-6xl font-bold text-indigo-600">404</p>
    <h1 class="text-xl font-semibold text-gray-900">Page not found</h1>
    <p class="text-gray-500">The page you're looking for doesn't exist.</p>
    <a
      href="/"
      class="mt-2 rounded-lg bg-indigo-600 px-4 py-2 font-medium text-white hover:bg-indigo-700"
    >
      Go home
    </a>
  </main>
</Layout>
